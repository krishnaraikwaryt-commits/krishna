<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Krishna CRM | Secure Access</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { background-color: #0f172a; color: #f8fafc; font-family: sans-serif; }
        .glass-card { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); }
        .modal { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.8); z-index: 50; align-items: center; justify-content: center; }
        .modal.active { display: flex; }
        #main-crm { display: none; } /* Dashboard hidden by default */
        #login-screen { display: flex; }
    </style>
</head>
<body class="min-h-screen">

    <div id="login-screen" class="fixed inset-0 flex items-center justify-center p-4 bg-slate-950 z-[100]">
        <div class="glass-card w-full max-w-md p-8 rounded-3xl shadow-2xl border-t-4 border-blue-600">
            <h1 class="text-3xl font-black text-blue-500 mb-2 text-center tracking-tighter">KRISHNA CRM</h1>
            <p class="text-gray-500 text-center mb-8 text-sm uppercase tracking-widest font-bold">Secure Login</p>
            <div class="space-y-4">
                <div class="relative">
                    <i class="fas fa-lock absolute left-4 top-4 text-gray-500"></i>
                    <input type="password" id="passInput" placeholder="Enter Access Code" class="w-full bg-slate-900 border border-white/10 p-4 pl-12 rounded-2xl outline-none focus:border-blue-500 transition-all text-xl tracking-widest">
                </div>
                <button onclick="checkLogin()" class="w-full bg-blue-600 hover:bg-blue-700 p-4 rounded-2xl font-black text-lg shadow-lg shadow-blue-500/20 transition-all active:scale-95">UNLOCK DASHBOARD</button>
                <p id="loginError" class="text-red-500 text-center text-xs hidden font-bold">❌ Access Denied! Wrong Code.</p>
            </div>
        </div>
    </div>

    <div id="main-crm" class="flex flex-col md:flex-row min-h-screen">
        <aside class="hidden md:flex w-64 bg-slate-900 p-6 flex-col space-y-8 border-r border-white/5">
            <div class="flex items-center space-x-2">
                <div class="w-3 h-3 bg-green-500 rounded-full animate-pulse"></div>
                <span class="text-xs font-bold text-gray-400">ADMIN ONLINE</span>
            </div>
            <nav class="space-y-4 flex-1">
                <a href="#" class="flex items-center space-x-3 text-blue-400 font-medium p-2 bg-blue-500/10 rounded-lg"><i class="fas fa-home"></i> <span>Dashboard</span></a>
                <button onclick="logout()" class="w-full flex items-center space-x-3 text-red-400 hover:text-red-500 p-2 mt-20 transition"><i class="fas fa-sign-out-alt"></i> <span>Logout</span></button>
            </nav>
        </aside>

        <main class="flex-1 p-4 md:p-8 space-y-6">
            <header class="flex justify-between items-center">
                <h2 class="text-2xl font-bold">Control Center</h2>
                <button onclick="toggleModal()" class="bg-blue-600 px-6 py-2 rounded-lg font-bold text-sm">+ ADD LEAD</button>
            </header>

            <div class="grid grid-cols-2 lg:grid-cols-4 gap-4" id="stats-grid">
                </div>

            <div class="glass-card rounded-2xl overflow-hidden">
                <div class="p-4 border-b border-white/5 flex gap-2">
                    <input type="text" id="searchInput" onkeyup="renderLeads()" placeholder="Search..." class="flex-1 bg-slate-800 p-2 rounded-lg text-sm outline-none">
                </div>
                <div class="overflow-x-auto text-sm">
                    <table class="w-full text-left">
                        <thead class="bg-white/5 text-gray-500 text-[10px] uppercase">
                            <tr>
                                <th class="p-4">Customer</th>
                                <th class="p-4">Status</th>
                                <th class="p-4 text-center">Score</th>
                                <th class="p-4 text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody id="lead-list"></tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <div id="leadModal" class="modal p-4">
        <div class="glass-card w-full max-w-md p-8 rounded-3xl">
            <h2 class="text-xl font-bold mb-4 text-blue-400">Lead Details</h2>
            <form id="leadForm" class="space-y-4">
                <input type="text" id="name" placeholder="Name" class="w-full bg-slate-800 p-3 rounded-xl outline-none" required>
                <input type="text" id="phone" placeholder="Phone" class="w-full bg-slate-800 p-3 rounded-xl outline-none" required>
                <select id="status" class="w-full bg-slate-800 p-3 rounded-xl outline-none">
                    <option value="New">New</option>
                    <option value="Interested">Interested</option>
                    <option value="Closed">Closed</option>
                </select>
                <button type="submit" class="w-full bg-blue-600 p-3 rounded-xl font-bold mt-4">Save Lead</button>
                <button type="button" onclick="toggleModal()" class="w-full text-gray-500 font-bold">Cancel</button>
            </form>
        </div>
    </div>

    <script>
        const ACCESS_CODE = "1234"; // Default Password

        function checkLogin() {
            const pass = document.getElementById('passInput').value;
            if(pass === ACCESS_CODE) {
                document.getElementById('login-screen').style.display = 'none';
                document.getElementById('main-crm').style.display = 'flex';
                renderLeads();
            } else {
                document.getElementById('loginError').classList.remove('hidden');
            }
        }

        function logout() {
            location.reload(); // Simple way to lock again
        }

        function toggleModal() { document.getElementById('leadModal').classList.toggle('active'); }

        // Logic for Leads
        document.getElementById('leadForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const leads = JSON.parse(localStorage.getItem('crmLeads') || '[]');
            const status = document.getElementById('status').value;
            let score = status === 'Closed' ? 15 : (status === 'Interested' ? 10 : 5);
            
            leads.push({
                id: Date.now(),
                name: document.getElementById('name').value,
                phone: document.getElementById('phone').value,
                status: status,
                score: score
            });
            localStorage.setItem('crmLeads', JSON.stringify(leads));
            toggleModal();
            document.getElementById('leadForm').reset();
            renderLeads();
        });

        function renderLeads() {
            const leads = JSON.parse(localStorage.getItem('crmLeads') || '[]');
            const search = document.getElementById('searchInput').value.toLowerCase();
            const list = document.getElementById('lead-list');
            list.innerHTML = '';

            leads.filter(l => l.name.toLowerCase().includes(search)).reverse().forEach(l => {
                list.innerHTML += `
                    <tr class="border-b border-white/5">
                        <td class="p-4 font-bold text-white">${l.name}<div class="text-[10px] text-gray-500 font-normal">${l.phone}</div></td>
                        <td class="p-4"><span class="px-2 py-0.5 rounded text-[9px] font-bold bg-blue-500/10 text-blue-500">${l.status}</span></td>
                        <td class="p-4 text-center font-bold text-blue-400">${l.score}</td>
                        <td class="p-4 text-center">
                            <a href="https://wa.me/91${l.phone}" target="_blank" class="text-green-500 mr-2"><i class="fab fa-whatsapp"></i></a>
                            <button onclick="deleteLead(${l.id})" class="text-red-500/30"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>`;
            });
        }

        window.deleteLead = (id) => {
            let leads = JSON.parse(localStorage.getItem('crmLeads') || '[]');
            leads = leads.filter(l => l.id !== id);
            localStorage.setItem('crmLeads', JSON.stringify(leads));
            renderLeads();
        }
    </script>
</body>
</html>